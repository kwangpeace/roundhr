INPUT_JSON_PATH=examples/sample_candidates.json
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
# Optional: comma-separated model fallbacks if the primary model is overloaded
# GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash-lite
# Optional: custom endpoint (Gemini default is auto-set)
# LLM_BASE_URL=
# Backward compatibility (optional):
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
JD_FALLBACK=
MASK_CANDIDATE_NAMES=false
DRY_RUN=false
MOCK_LLM=false
# 로컬 샘플 실행 시 시간 구간 필터를 끄려면 false (GitHub Actions에서는 워크플로가 true로 설정)
APPLIED_TIME_FILTER=false
